#!/usr/bin/env bash
set -euo pipefail

vouch_lib_dir="${VOUCH_LIB_DIR:-}"

if [ -z "$vouch_lib_dir" ]; then
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  vouch_lib_dir="$(cd -- "$script_dir/../.." && pwd)/vouch"
fi

export VOUCH_LIB_DIR="$vouch_lib_dir"

nu_lib_dir="${VOUCH_LIB_DIR//\\/\\\\}"
nu_lib_dir="${nu_lib_dir//\"/\\\"}"

quote_nu_arg() {
  if [[ "$1" =~ ^[A-Za-z0-9_./:@%+=,-]+$ ]]; then
    printf '%s' "$1"
  else
    local arg="${1//\\/\\\\}"
    arg="${arg//\"/\\\"}"
    printf '"%s"' "$arg"
  fi
}

cmd=""
for a in "$@"; do
  cmd="$cmd $(quote_nu_arg "$a")"
done

# With no args, call 'vouch main' for usage info since bare
# 'vouch' doesn't resolve via 'use vouch *'.
if [ $# -eq 0 ]; then
  cmd="vouch main"
fi

exec nu --no-config-file -c "use \"$nu_lib_dir\" *; $cmd"
